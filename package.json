{
  "name": "scout-ai",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Scout AI - football talent discovery platform for Africa",
  "scripts": {
    "dev": "concurrently -k -n server,vite \"node server.js\" \"vite\"",
    "server": "node server.js",
    "prebuild": "node -e \"const fs=require('fs');fs.mkdirSync('public/ffmpeg',{recursive:true});fs.copyFileSync('node_modules/@ffmpeg/core/dist/umd/ffmpeg-core.js','public/ffmpeg/ffmpeg-core.js');fs.copyFileSync('node_modules/@ffmpeg/core/dist/umd/ffmpeg-core.wasm','public/ffmpeg/ffmpeg-core.wasm');\"",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@ffmpeg/core": "^0.12.6",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.1",
    "@google/genai": "^1.9.0",
    "@supabase/supabase-js": "^2.49.4",
    "cors": "^2.8.6",
    "express": "^4.22.2",
    "formidable": "^3.5.4",
    "multer": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.4",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^10.0.3",
    "tailwindcss": "^4.1.4",
    "vite": "^6.3.2"
  }
}
